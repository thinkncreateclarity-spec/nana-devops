#!/usr/bin/env node
const args = process.argv.slice(2);
const input = args.join(' ');

if (input.includes(';')) {
  // Matrix mode
  console.log('🧮 Matrix: ' + input);
  console.log('Science: det sin cos log exp sqrt fact');
} else if (args[0] === 'black') {
  const [S, K, T, r, sigma] = args.slice(1).map(parseFloat);
  const d1 = (Math.log(S/K) + (r + 0.5*sigma*sigma)*T) / (sigma*Math.sqrt(T));
  const d2 = d1 - sigma*Math.sqrt(T);
  const call = S * 0.8413 - K * Math.exp(-r*T) * 0.6915; // N(d1), N(d2) approx
  console.log(`💹 Black-Scholes Call: $${call.toFixed(2)}`);
  console.log('💎 Pro: Full Greeks → revenue upi');
} else {
  try {
    const result = eval(input);
    console.log(`🧮 ${result}`);
  } catch {
    console.log('calc "expr" | matrix | black S K T r sigma');
  }
}
