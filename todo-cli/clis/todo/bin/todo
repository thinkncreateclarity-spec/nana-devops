#!/usr/bin/env node
const args = process.argv.slice(2);
if (args[0] === 'login') {
  console.log('UPI QR: upi://pay?pa=ajay@paytm&am=1');
  console.log('Scan with PhonePe/GPay - 7 Day Pro!');
} else if (args[0] === 'add' && args[1]) {
  console.log('Added: ' + args[1]);
} else if (args[0] === 'list') {
  console.log('1. Buy milk');
  console.log('2. Deploy CLI empire');
} else {
  console.log('todo login | add "text" | list');
}
